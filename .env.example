# Copie para .env e preencha com seus valores locais:
# cp .env.example .env

# Senha do PostgreSQL (Neon) — NÃO commite o arquivo .env
QUARKUS_DATASOURCE_PASSWORD=sua_senha_neon_aqui

# Opcional: sobrescrever URL do banco
# QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://...

# Opcional: CORS para desenvolvimento local
# QUARKUS_HTTP_CORS_ORIGINS=http://localhost:3000
