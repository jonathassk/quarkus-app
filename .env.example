# ==============================================================================
# .env.example — Template de variáveis de ambiente
# ==============================================================================
# Copie para .env e preencha com seus valores locais:
#   cp .env.example .env
#
# NUNCA commite o arquivo .env — ele está no .gitignore.
# NUNCA coloque credenciais reais neste arquivo .env.example.
# ==============================================================================

# --- Banco de dados (Neon PostgreSQL) ---
QUARKUS_DATASOURCE_PASSWORD=sua_senha_neon_aqui

# Opcional: URL do banco completa (sobrescreve o padrão em application.properties)
# QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://seu-endpoint.neon.tech:5432/neondb?sslmode=require

# --- Hibernate (dev: habilita atualização automática de schema) ---
# Remova ou deixe como 'none' em produção/staging
QUARKUS_HIBERNATE_ORM_DATABASE_GENERATION=update

# --- Neon Auth (JWT EdDSA) ---
NEON_AUTH_BASE_URL=https://seu-endpoint.neonauth.c-4.us-east-1.aws.neon.tech/neondb/auth
NEON_AUTH_JWKS_URL=https://seu-endpoint.neonauth.c-4.us-east-1.aws.neon.tech/neondb/auth/.well-known/jwks.json
NEON_AUTH_ISSUER=https://seu-endpoint.neonauth.c-4.us-east-1.aws.neon.tech/neondb/auth
# Opcional: chave EdDSA em cache JSON (deixe vazio para buscar do JWKS_URL dinamicamente)
NEON_AUTH_JWK_JSON=

# --- Stripe (use apenas chaves de TESTE sk_test_...) ---
STRIPE_API_KEY=sk_test_sua_chave_stripe_aqui
STRIPE_WEBHOOK_SECRET=whsec_seu_webhook_secret_aqui
STRIPE_SUCCESS_URL=http://localhost:3000/payment/success
STRIPE_CANCEL_URL=http://localhost:3000/payment/cancel

# Stripe Price IDs (ambiente de teste)
STRIPE_PRICE_MENSAL=price_seu_price_id_aqui
STRIPE_PRICE_ANUAL=price_seu_price_id_aqui
STRIPE_PRICE_MENSAL_AGENT=price_seu_price_id_aqui
STRIPE_PRICE_ANUAL_AGENT=price_seu_price_id_aqui

# --- Segredo interno para rotas protegidas ---
# Gere um valor forte com: openssl rand -hex 32
INTERNAL_SECRET=seu_segredo_interno_forte_com_minimo_32_caracteres

# E-mails automáticos (produto / lembretes) ficam na Lambda Go: services/email-worker
# Ver docs/SES_SETUP.md

# --- Cloudflare R2 (storage de documentos de viagem) ---
R2_BUCKET_NAME=nome-do-seu-bucket-r2
R2_ENDPOINT=https://seu-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=seu_r2_access_key_id
R2_SECRET_ACCESS_KEY=seu_r2_secret_access_key

# --- CORS (opcional em dev, obrigatório em prod) ---
# QUARKUS_HTTP_CORS_ORIGINS=http://localhost:3000
